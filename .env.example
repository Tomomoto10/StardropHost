# ===========================================
# StardropHost | .env
# ===========================================
# Just run:
#   docker compose up -d
#
# Then open:
#   http://your-server-ip:18642
#
# The setup wizard will handle everything!
# ===========================================


# -- Game Files --
# Set automatically by the setup wizard
GAME_PATH=
STEAM_DOWNLOAD=false


# -- Resources --
# Set automatically by the setup wizard
CPU_LIMIT=2.0
MEMORY_LIMIT=2G


# -- VNC --
# Off by default, toggle via web UI
ENABLE_VNC=false
VNC_PASSWORD=


# -- Rendering --
DISABLE_RENDERING=true
USE_GPU=false


# -- Display --
RESOLUTION_WIDTH=1280
RESOLUTION_HEIGHT=720
REFRESH_RATE=60


# -- Performance --
LOW_PERF_MODE=false
TARGET_FPS=


# -- Timezone --
TZ=UTC


# -- Logging --
ENABLE_LOG_MONITOR=true


# -- Backups --
# 1 backup per day at 4am, kept for 7 days
ENABLE_AUTO_BACKUP=true
MAX_BACKUPS=7
BACKUP_HOUR=4
BACKUP_COMPRESSION_LEVEL=1


# -- Crash Recovery --
ENABLE_CRASH_RESTART=false
MAX_CRASH_RESTARTS=5


# -- Save --
SAVE_NAME=


# -- Network --
PUBLIC_IP=


# ===========================================
# Troubleshooting
# ===========================================
#
# Players can't connect:
#   Ensure port 24642/udp is open in your firewall
#   Ubuntu/Debian:  sudo ufw allow 24642/udp
#   CentOS/RHEL:    sudo firewall-cmd --add-port=24642/udp --permanent
#
# For help:
#   https://github.com/Tomomoto10/StardropHost
# ===========================================